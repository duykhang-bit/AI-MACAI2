<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- parallel="classes" + thread-count="6" = 6 class chạy cùng lúc -->
<suite name="RSA  CI Suite" verbose="1" parallel="classes" thread-count="4">

    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="utils.DashboardReportGenerator"/>
    </listeners>

    <test name="UAT Tests">
        <classes>
            <!-- Promotion RSA Tests -->
            <class name="testcases.PromotionRsa.TC7"/>
            <class name="testcases.PromotionRsa.TC8"/>
            <class name="testcases.PromotionRsa.TC9"/>
            <class name="testcases.PromotionRsa.TC10"/>
     

            <!-- Family Tests -->
            <!--
            <class name="testcases.Family.WebRSAUAT"/>
            <class name="testcases.Family.WebRSAUAT1"/>
            <class name="testcases.Family.WebRSAUAT2"/>
            <class name="testcases.Family.WebRSAUAT3"/>
            <class name="testcases.Family.WebRSAUAT4"/>
            <class name="testcases.Family.WebRSAUAT5"/>
            <class name="testcases.Family.WebRSAUAT6"/>
            -->
        </classes>
    </test>

</suite>
